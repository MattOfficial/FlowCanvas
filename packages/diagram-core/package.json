{
  "name": "@flownote/diagram-core",
  "version": "0.1.0",
  "description": "Framework-agnostic diagram domain logic for FlowNote-style editors.",
  "keywords": [
    "diagram",
    "canvas",
    "whiteboard",
    "typescript",
    "flownote"
  ],
  "homepage": "https://github.com/MattOfficial/FlowCanvas#readme",
  "bugs": {
    "url": "https://github.com/MattOfficial/FlowCanvas/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MattOfficial/FlowCanvas.git",
    "directory": "packages/diagram-core"
  },
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
